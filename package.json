{
  "name": "reference-vscode",
  "displayName": "Smart VSCode Copy",
  "description": "Reference code snippets easily and consistently",
  "version": "1.0.0",
  "publisher": "samlloydw",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/samlloydw/Reference-VSCode"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "reference-vscode.simple-reference",
        "title": "Simple Reference",
        "category": "Reference"
      },
      {
        "command": "reference-vscode.detailed-reference",
        "title": "Code Block Reference",
        "category": "Reference"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorHasSelection",
          "command": "reference-vscode.simple-reference",
          "group": "9_cutcopypaste@1"
        },
        {
          "when": "editorHasSelection",
          "command": "reference-vscode.detailed-reference",
          "group": "9_cutcopypaste@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "reference-vscode.simple-reference",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "editorHasSelection"
      },
      {
        "command": "reference-vscode.detailed-reference",
        "key": "ctrl+alt+shift+c",
        "mac": "cmd+alt+shift+c",
        "when": "editorHasSelection"
      }
    ],
    "configuration": {
      "title": "Reference VSCode",
      "properties": {
        "reference-vscode.includeGitInfo": {
          "type": "boolean",
          "default": true,
          "description": "Include Repository URL and Commit Hash in the reference."
        },
        "reference-vscode.referenceStyle": {
          "type": "string",
          "enum": ["Standard", "GitHubLink", "Minimalist"],
          "default": "Standard",
          "description": "Choose the formatting style for the metadata."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
