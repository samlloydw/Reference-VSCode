{
  "name": "reference-vscode",
  "displayName": "reference-vscode",
  "description": "Reference code snippets easily and consistently",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "reference-vscode.simple-reference",
        "title": "Simple Reference",
        "category": "Reference"
      },
      {
        "command": "reference-vscode.detailed-reference",
        "title": "Code Block Reference",
        "category": "Reference"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorHasSelection",
          "command": "reference-vscode.simple-reference",
          "group": "9_cutcopypaste@1"
        },
        {
          "when": "editorHasSelection",
          "command": "reference-vscode.detailed-reference",
          "group": "9_cutcopypaste@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "reference-vscode.simple-reference",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "editorHasSelection"
      },
      {
        "command": "reference-vscode.detailed-reference",
        "key": "ctrl+alt+shift+c",
        "mac": "cmd+alt+shift+c",
        "when": "editorHasSelection"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
